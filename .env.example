# Copy to .env and fill in. Never commit .env — enforced by .gitignore and the Policy Engine.

# Postgres (local Docker by default — see docker-compose.yml)
DATABASE_URL=postgresql://gridiron:gridiron_dev_only@localhost:5432/gridiron_dev

# Claude Agent SDK — required from Day 5 (agent-runtime) onward
ANTHROPIC_API_KEY=

# Repository the Developer Agent reads/plans/patches against.
# Self-referential (this monorepo) until a real target repo is assigned — see PROJECT.md.
TARGET_REPO_PATH=.
