# Copy to .env and fill in. Never commit .env — enforced by .gitignore and the Policy Engine.
# All variables validated at startup by packages/shared-config (Zod schema — missing required vars crash with clear message).

# ── Database ──────────────────────────────────────────────────────────────────
# Postgres (local Docker by default — see docker-compose.yml)
DATABASE_URL=postgresql://gridiron:gridiron_dev_only@localhost:5432/gridiron_dev

# ── AI Models ─────────────────────────────────────────────────────────────────
# Anthropic — required to run agents
ANTHROPIC_API_KEY=

# Model names — swap without code changes (see CLAUDE.md model tiering)
MODEL_PLANNER=claude-sonnet-4-6
MODEL_CODER=claude-sonnet-4-6
MODEL_ROUTER=claude-haiku-4-5-20251001

# ── Embeddings ────────────────────────────────────────────────────────────────
# Voyage AI — required for semantic code search (voyage-code-2, 1536 dims)
# Free tier at voyageai.com. Without it, system falls back to keyword-only search.
VOYAGE_API_KEY=

# ── Repository paths ──────────────────────────────────────────────────────────
# Repository the agents read/plan/patch against.
# Self-referential (this monorepo) until a real target repo is assigned.
TARGET_REPO_PATH=.

# Where git worktrees for coding tasks are created (isolated sandboxes)
WORKTREES_DIR=/tmp/gridiron/worktrees

# ── Agent behaviour ───────────────────────────────────────────────────────────
# Max self-correction retries before task → blocked
MAX_RETRIES=3

# Log level: debug | info | warn | error
LOG_LEVEL=info

# Planning mode: simple (single planner agent) | full (PM→Architect→Decomposer pipeline)
PIPELINE_MODE=full

# Context builder character budget sent to agents (proxy for token budget)
CONTEXT_BUDGET_CHARS=40000
